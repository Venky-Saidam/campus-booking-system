            //         },
            //         1900: {
            //             items: 5,
            //         },
            //     },
            // });
            $('.event-carousel').owlCarousel({
                loop: true,
                margin: 10,
                nav: false,
                autoplay: true,
                autoplayTimeout: 5000,
                dots: false,
                responsive: {
                    0: {
                        items: 1
                    },
                    600: {
                        items: 3
                    },
                    1000: {
                        items: 2
                    }
                }
            })
            $(document).ready(function() {
                new DataTable('.dataTbl', {
                    "bDestroy": true,
                    ordering: false,
                });
            });
        });
    </script>
    <script>
        const button = document.querySelector(".top-to-scroll");

        const displayButton = () => {
            window.addEventListener("scroll", () => {
                //console.log(window.scrollY);

                if (window.scrollY > 300) {
                    button.style.display = "block";
                } else {
                    button.style.display = "none";
                }
            });
        };

        const scrollToTop = () => {
            button.addEventListener("click", () => {
                window.scroll({
                    top: 0,
                    left: 0,
                    behavior: "smooth",
                });
                //console.log(event);
            });
        };

        displayButton();
        scrollToTop();
    </script>
    <script>
        $(document).ready(function() {
            $(".stellarnav").hide();
            $("#mobile-menu").click(function() {
                $(".stellarnav").show();
            });
            $("#close-mobile-menu").click(function() {
                $(".stellarnav").hide();
            });

        });

        //main website ka scoller hai
        $('.banner-carousel').owlCarousel({
            loop: true,
            margin: 0,
            nav: false,
            dot: false,
            autoplay: true,
            responsive: {
                0: {
                    items: 1
                },
                600: {
                    items: 1
                },
                1000: {
                    items: 1
                }
            }
        })
    </script>
    <script>
        var $affectedElements = $("p, h1, h2, h3, h4, h5, h6");

        $affectedElements.each(function() {
            var $this = $(this);
            $this.data("orig-size", $this.css("font-size"));
        });

        $("#btn-increase").click(function() {
            changeFontSize(1);
        })

        $("#btn-decrease").click(function() {
            changeFontSize(-1);
        })

        $("#btn-orig").click(function() {
            $affectedElements.each(function() {
                var $this = $(this);
                $this.css("font-size", $this.data("orig-size"));
            });
        })

        function changeFontSize(direction) {
            $affectedElements.each(function() {
                var $this = $(this);
                $this.css("font-size", parseInt($this.css("font-size")) + direction);
            });
        }
        //console.log(localStorage);

        $('body').toggleClass(localStorage.toggled);

        $("#changeColor").on('click', function() {
            if (localStorage.toggled != 'background-black') {
                $('body').toggleClass('background-black', true);
                localStorage.toggled = "background-black";
            } else if (localStorage.toggled == 'background-black') {
                $('body').toggleClass('background-black', false);
                localStorage.toggled = "";

            }
        });
    </script>
