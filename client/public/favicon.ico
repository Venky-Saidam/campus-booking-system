    <style>
        .tooltip-inner {
            max-width: 200px;
            padding: .25rem .5rem;
            color: #000000;
            text-align: center;
            background-color: #ffd049;
            border-radius: .25rem;
        }

        .bs-tooltip-auto[data-popper-placement^=top] .tooltip-arrow::before,
        .bs-tooltip-top .tooltip-arrow::before {
            top: -1px;

            border-top-color: #ffd049;
        }

