        $(document).ready(function() {
            $('iframe[src*="youtube.com"]').each(function() {
                $(this).attr('referrerpolicy', 'strict-origin-when-cross-origin');
                // Reload the iframe to apply the new policy
                var src = $(this).attr('src');
                $(this).attr('src', src);
            });
